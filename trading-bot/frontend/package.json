{
  "name": "tradebot-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard frontend (TypeScript + Alpine + ECharts + Tailwind).",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/styles/app.css -o ../tradebot/web/static/css/app.css --minify",
    "build:js": "node esbuild.mjs",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "tailwindcss -i src/styles/app.css -o ../tradebot/web/static/css/app.css --watch",
    "watch:js": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "alpinejs": "^3.14.1",
    "echarts": "^5.5.1"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.10",
    "esbuild": "^0.23.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
