# Copy to `.env` and fill in. NEVER commit your real .env (it is gitignored).
#
# Get free API keys from https://app.alpaca.markets/ -> "Paper Trading" ->
# "Generate API Keys". Paper keys cannot touch real money.

ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here

# Data feed: "iex" (free) or "sip" (paid, full-market). Start with iex.
ALPACA_DATA_FEED=iex

# Live-trading safety latch. Leave UNSET for paper trading. Only set this to
# the exact value below when you have switched mode: live in config.yaml AND
# you genuinely intend to risk real money.
# TRADEBOT_LIVE_CONFIRM=I_UNDERSTAND
