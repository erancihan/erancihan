{
  "name": "antigravity-parallel-agents",
  "displayName": "Swarm — Parallel Sandboxed Chats",
  "version": "0.0.0",
  "private": true,
  "description": "Bake parallel, fully-isolated chats into the Antigravity IDE: every chat is a lane running in its own git worktree + OS sandbox.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "keywords": ["antigravity", "gemini", "agents", "parallel", "sandbox", "worktree", "isolation"],
  "license": "MIT",
  "main": "./dist-ext/extension.cjs",
  "bin": { "swarm": "./dist/cli/main.js" },
  "activationEvents": ["onChatParticipant:swarm.lanes", "onView:swarm.lanesPanel"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ext": "tsc -p extension/tsconfig.json",
    "bundle:ext": "esbuild extension/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist-ext/extension.cjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "swarm.lanes",
        "name": "swarm",
        "description": "Spin off a parallel, sandboxed chat lane",
        "commands": [
          { "name": "fork", "description": "Fork this chat into an isolated lane" },
          { "name": "run", "description": "Start a new lane for a task" },
          { "name": "lanes", "description": "Open the Lanes panel" }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "swarm", "title": "Swarm", "icon": "extension/media/swarm.svg" }
      ]
    },
    "views": {
      "swarm": [
        { "id": "swarm.lanesPanel", "name": "Lanes", "type": "webview" }
      ]
    },
    "configuration": {
      "title": "Swarm",
      "properties": {
        "swarm.command": {
          "type": "string",
          "default": "antigravity",
          "description": "Executable used to drive each lane's agent."
        },
        "swarm.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["agent", "run", "--cwd", "${worktree}", "--prompt", "${prompt}"],
          "description": "Argument template per lane. Tokens: ${prompt} ${worktree} ${agentsMdPath}."
        },
        "swarm.concurrency": {
          "type": "number",
          "default": 4,
          "description": "Maximum lanes running at once."
        }
      }
    },
    "commands": [
      { "command": "swarm.newRun", "title": "Swarm: New Run" },
      { "command": "swarm.addLane", "title": "Swarm: Add Lane" },
      { "command": "swarm.openPanel", "title": "Swarm: Open Lanes Panel" },
      { "command": "swarm.mergeLane", "title": "Swarm: Merge Lane" },
      { "command": "swarm.discardLane", "title": "Swarm: Discard Lane" }
    ]
  }
}
