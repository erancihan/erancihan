#!/usr/bin/env bash
# pre-push hook: Update submodule references to latest remote HEAD before pushing.
# This ensures pushed commits always reference the latest submodule state.
#
# Install: cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#   or:    git config core.hooksPath .githooks

set -euo pipefail

echo "🔄 Updating submodule references to latest remote HEAD..."

# Update each submodule to track the latest remote commit
git submodule update --remote --merge 2>/dev/null || {
  echo "⚠️  Failed to update submodules (network issue?). Skipping."
  exit 0
}

# If submodules were updated, stage and amend the current HEAD commit
if ! git diff --quiet; then
  echo "📦 Submodule references changed. Staging updates..."
  git add -A

  # Auto-commit the submodule update
  git commit --no-verify -m "chore: update submodule references"
  echo "✅ Submodule references updated and committed."
else
  echo "✅ All submodule references are already up to date."
fi
