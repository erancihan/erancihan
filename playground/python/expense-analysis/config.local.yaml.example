# Example local config file. Copy this to config.local.yaml and edit.
# Any values here override the defaults in src/config.py.

# database_url: "sqlite:///data/expenses.db"
# gmail_credentials_path: "secrets/credentials.json"
# gmail_token_path: "secrets/token.json"
# check_interval_minutes: 30

# ── Web / auth ───────────────────────────────────────────────────
# REQUIRED in production: a long random string used to sign session cookies.
#   python -c "import secrets; print(secrets.token_hex(32))"
# secret_key: "change-me-to-a-long-random-value"
# Set true when serving over HTTPS so the session cookie is TLS-only.
# session_cookie_secure: true
# Public self-sign-up is OFF by default; create users with scripts/create_user.py.
# allow_registration: false
# Number of trusted reverse proxies in front of the app (1 for a single nginx/
# Caddy). Enables reading the real client IP/scheme from X-Forwarded-* headers.
# trusted_proxies: 1
# Rate limit on the login endpoint (brute-force defense).
# login_ratelimit: "10 per minute"
# Exchange rates to TRY for cross-currency totals. Foreign spend is converted in
# the dashboard's TRY-equivalent total; currencies without a rate are left out.
# exchange_rates:
#   USD: 34.0
#   EUR: 37.0

# bank_config:
#   isbank:
#     senders:
#       - bilgilendirme@ileti.isbank.com.tr
#     subject_keywords:
#       - Ekstre
#       - Kredi Kartı Hesap Özeti
